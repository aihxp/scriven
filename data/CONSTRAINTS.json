    },
    "essay_collection": {
      "label": "Essay Collection",
      "group": "prose",
      "hierarchy": { "top": "part", "mid": null, "atomic": "essay" },
      "command_unit": "essay"
    },
    "screenplay": {
      "label": "Screenplay",
      "group": "script",
      "hierarchy": { "top": "act", "mid": "sequence", "atomic": "scene" },
      "command_unit": "act"
    },
    "stage_play": {
      "label": "Stage Play",
      "group": "script",
      "hierarchy": { "top": "act", "mid": "scene", "atomic": "beat" },
