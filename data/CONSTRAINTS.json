      "command_unit": "section"
    },
    "white_paper": {
      "label": "White Paper",
      "group": "academic",
      "hierarchy": { "top": null, "mid": "section", "atomic": "subsection" },
      "command_unit": "section"
    },
    "literature_review": {
      "label": "Literature Review",
      "group": "academic",
      "hierarchy": { "top": null, "mid": "section", "atomic": "subsection" },
      "command_unit": "section"
    },
    "monograph": {
      "label": "Monograph",
      "group": "academic",
      "hierarchy": { "top": "part", "mid": "chapter", "atomic": "section" },
